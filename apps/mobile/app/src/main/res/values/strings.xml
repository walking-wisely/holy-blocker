<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      translatable="false" is load-bearing, not tidiness. SettingsGuard matches
      settings screens by looking for this label in the node tree, which works
      only because it is a brand string rather than localised copy. A translated
      app_name would silently disable the catch-all in that locale — the exact
      failure the guard avoids by never matching Settings' own wording.
    -->
    <string name="app_name" translatable="false">Holy Blocker</string>

    <!--
      Shown on the system's accessibility settings screen. States what the
      service reads, since the user is granting a broad permission.
    -->
    <string name="accessibility_service_description">Reads on-screen text so it can cover content that matches your settings. Text is analysed on this device and is never sent anywhere.</string>

    <!--
      Overlay copy. Per docs/decisions/formation-model.md these describe what the
      tool did — they never name a fault or address the person's conscience.
    -->
    <string name="overlay_covered">Covered</string>
    <string name="overlay_warn">Heads up</string>

    <!-- Onboarding -->
    <string name="onboarding_title">Holy Blocker</string>
    <string name="status_service_on">Screen guard is on.</string>
    <string name="status_service_off">Screen guard is off.</string>
    <string name="action_open_accessibility_settings">Open accessibility settings</string>
    <string name="restricted_settings_hint">If the toggle is greyed out, open App info, tap the three-dot menu, and choose “Allow restricted settings”. Android requires this for apps installed outside the Play Store.</string>

    <!--
      The exit path. Deliberately plain and always reachable: a tool that cannot
      be switched off is not an accountability tool, and this is also the only
      in-app recovery if screen matching misfires on an untested device.
    -->
    <string name="action_request_release">Request access to settings</string>
    <string name="action_cancel_release">Cancel request</string>
    <string name="status_release_pending">Settings unlock in %1$d min. You can cancel any time.</string>
    <string name="status_release_open">Settings are open for %1$d more seconds.</string>

    <!--
      Shown when the device has no verified settings-screen identifiers. Failing
      visibly beats failing open: the guard genuinely is not running here, and
      claiming otherwise would be the one thing worse than not having it.
    -->
    <string name="status_device_unsupported">Screen protection is unverified on this device — settings are not guarded.</string>

    <!--
      Device admin. The explanation is shown on the system activation screen and
      the warning on the deactivation screen; both state the consequence and stop
      there, per docs/decisions/formation-model.md.
    -->
    <string name="admin_status_on">Uninstall protection is on.</string>
    <string name="admin_status_off">Uninstall protection is off.</string>
    <string name="action_enable_admin">Turn on uninstall protection</string>
    <string name="admin_add_explanation">While this is on, Holy Blocker cannot be uninstalled until you turn it off again. It grants no other permissions — it cannot lock, wipe, or change your device.</string>
    <string name="admin_disable_warning">Turning this off lets Holy Blocker be uninstalled again.</string>
</resources>
