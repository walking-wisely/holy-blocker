# Copy to .env and fill in. .env is gitignored — never commit real tokens.
#
# Nothing here is used by the shipped product. These are dev-time credentials
# for fetching evaluation corpora; the blocker itself makes no network calls.

# Hugging Face read token, used by `holy-blocker-extract` to download the gated
# evaluation dataset. Gating is automatic — no human review:
#   1. Accept the terms at https://huggingface.co/datasets/deepghs/nsfw_detect
#   2. Create a read token at https://huggingface.co/settings/tokens
HF_TOKEN=
